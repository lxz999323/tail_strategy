# ============================================================
# 环境变量配置模板 - 复制为 .env 并填入真实值
# ============================================================

# 发件人邮箱（QQ邮箱/163等）
EMAIL_USER=your_qq_number@qq.com

# SMTP 授权码（非登录密码！）
# QQ邮箱: 设置 -> 账户 -> 生成授权码
EMAIL_PASSWORD=your_smtp_authorization_code

# SMTP 服务器（可选，默认 smtp.qq.com）
# EMAIL_SMTP_HOST=smtp.qq.com
# EMAIL_SMTP_PORT=465
# EMAIL_USE_SSL=true

# 收件人（可选，默认发给发件人自己，多个用逗号分隔）
# EMAIL_TO=your@email.com
